# ARCHITECT Configuration
# Copy to .env and fill in values

# Postgres
ARCHITECT_PG_HOST=localhost
ARCHITECT_PG_PORT=5432
ARCHITECT_PG_DATABASE=architect
ARCHITECT_PG_USER=architect
ARCHITECT_PG_PASSWORD=architect_dev

# Redis
ARCHITECT_REDIS_HOST=localhost
ARCHITECT_REDIS_PORT=6379
ARCHITECT_REDIS_DB=0
ARCHITECT_REDIS_PASSWORD=

# Temporal
ARCHITECT_TEMPORAL_HOST=localhost
ARCHITECT_TEMPORAL_PORT=7233
ARCHITECT_TEMPORAL_NAMESPACE=architect
ARCHITECT_TEMPORAL_TASK_QUEUE=architect-tasks

# Sandbox
ARCHITECT_SANDBOX_BASE_IMAGE=architect-sandbox:latest
ARCHITECT_SANDBOX_CPU_CORES=2
ARCHITECT_SANDBOX_MEMORY_MB=4096
ARCHITECT_SANDBOX_TIMEOUT_MINUTES=15
ARCHITECT_SANDBOX_DOCKER_SOCKET=/var/run/docker.sock

# Claude API
ARCHITECT_CLAUDE_API_KEY=sk-ant-...
ARCHITECT_CLAUDE_MODEL_ID=claude-sonnet-4-20250514
ARCHITECT_CLAUDE_MAX_CONTEXT_TOKENS=180000
ARCHITECT_CLAUDE_MAX_OUTPUT_TOKENS=16000
ARCHITECT_CLAUDE_TEMPERATURE=0.2

# Budget
ARCHITECT_BUDGET_TOTAL_TOKENS=10000000
ARCHITECT_BUDGET_WARNING_THRESHOLD_PCT=80.0
ARCHITECT_BUDGET_HARD_STOP_THRESHOLD_PCT=95.0

# General
ARCHITECT_LOG_LEVEL=INFO
ARCHITECT_ENVIRONMENT=dev
