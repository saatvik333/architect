# ARCHITECT Configuration
# Copy to .env and fill in values.
# Or run: scripts/dev-setup.sh (auto-generates passwords)

# Postgres — used by docker-compose AND Python services
POSTGRES_PASSWORD=  # REQUIRED: openssl rand -hex 16
ARCHITECT_PG_HOST=localhost
ARCHITECT_PG_PORT=5432
ARCHITECT_PG_DATABASE=architect
ARCHITECT_PG_USER=architect
ARCHITECT_PG_PASSWORD=  # REQUIRED: must match POSTGRES_PASSWORD

# Redis
REDIS_PASSWORD=  # REQUIRED: openssl rand -hex 16
ARCHITECT_REDIS_HOST=localhost
ARCHITECT_REDIS_PORT=6379
ARCHITECT_REDIS_DB=0
ARCHITECT_REDIS_PASSWORD=  # REQUIRED: must match REDIS_PASSWORD

# Temporal
ARCHITECT_TEMPORAL_HOST=localhost
ARCHITECT_TEMPORAL_PORT=7233
ARCHITECT_TEMPORAL_NAMESPACE=architect
ARCHITECT_TEMPORAL_TASK_QUEUE=architect-tasks

# Sandbox
ARCHITECT_SANDBOX_BASE_IMAGE=architect-sandbox:latest
ARCHITECT_SANDBOX_CPU_CORES=2
ARCHITECT_SANDBOX_MEMORY_MB=4096
ARCHITECT_SANDBOX_TIMEOUT_MINUTES=15
ARCHITECT_SANDBOX_DOCKER_SOCKET=/var/run/docker.sock

# Claude API
ARCHITECT_CLAUDE_API_KEY=sk-ant-...
ARCHITECT_CLAUDE_MODEL_ID=claude-sonnet-4-20250514
ARCHITECT_CLAUDE_MAX_CONTEXT_TOKENS=180000
ARCHITECT_CLAUDE_MAX_OUTPUT_TOKENS=16000
ARCHITECT_CLAUDE_TEMPERATURE=0.2

# Budget
ARCHITECT_BUDGET_TOTAL_TOKENS=10000000
ARCHITECT_BUDGET_WARNING_THRESHOLD_PCT=80.0
ARCHITECT_BUDGET_HARD_STOP_THRESHOLD_PCT=95.0

# API Gateway Authentication
ARCHITECT_GATEWAY_API_KEYS_RAW=  # Comma-separated API keys; generate with: openssl rand -hex 32
ARCHITECT_GATEWAY_AUTH_ENABLED=true

# Phase 3 Service Ports
KNOWLEDGE_MEMORY_PORT=8014
ECONOMIC_GOVERNOR_PORT=8015
HUMAN_INTERFACE_PORT=8016

# Grafana (REQUIRED: generate with `openssl rand -hex 16` or run scripts/dev-setup.sh)
GRAFANA_PASSWORD=

# NATS (REQUIRED: generate with `openssl rand -hex 16` or run scripts/dev-setup.sh)
NATS_TOKEN=

# WebSocket authentication (REQUIRED: generate with `openssl rand -hex 32` or run scripts/dev-setup.sh)
ARCHITECT_WS_TOKEN=

# Economic Governor (optional, defaults shown)
# ECON_GOV_ALERT_THRESHOLD_PCT=70
# ECON_GOV_RESTRICT_THRESHOLD_PCT=85
# ECON_GOV_HALT_THRESHOLD_PCT=95

# Phase 3 Service Configuration (optional, defaults shown)
# KM_COMPRESSION_BATCH_SIZE=100
# ECON_GOV_EFFICIENCY_RECALC_INTERVAL=60
# HUMAN_INTERFACE_DEFAULT_ESCALATION_EXPIRY_MINUTES=60

# General
ARCHITECT_LOG_LEVEL=INFO
ARCHITECT_ENVIRONMENT=dev
